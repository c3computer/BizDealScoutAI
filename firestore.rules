rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Defines
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // 2. Blueprint Validators
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'teamId', 'createdAt', 'updatedAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 150 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.teamId is string && data.teamId.size() <= 128 &&
             (!('picture' in data) || (data.picture is string && data.picture.size() < 1000)) &&
             (!('profile' in data) || data.profile is map) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidTeam(data) {
       return data.keys().hasAll(['name', 'tier', 'memberIds', 'ownerId', 'createdAt', 'updatedAt']) &&
              data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
              data.tier is string && data.tier in ['SOLOPRENEUR', 'FAMILY_OFFICE', 'M_AND_A'] &&
              data.memberIds is list && data.memberIds.size() <= 10 && data.memberIds.size() > 0 && (data.memberIds[0] is string) &&
              data.ownerId is string && data.ownerId.size() <= 128 &&
              (!('stripeCustomerId' in data) || data.stripeCustomerId is string) &&
              (!('stripeSubscriptionId' in data) || data.stripeSubscriptionId is string) &&
              (!('lifetimeAccess' in data) || data.lifetimeAccess is bool) &&
              data.createdAt is timestamp &&
              data.updatedAt is timestamp;
    }

    function isValidDeal(data, userId) {
      return data.keys().hasAll(['userId', 'url', 'savedAt', 'updatedAt']) &&
             data.userId == userId &&
             data.url is string && data.url.size() <= 1000 &&
             (!('dealData' in data) || data.dealData is map) &&
             (!('analysis' in data) || data.analysis is map) &&
             (!('metrics' in data) || data.metrics is map) &&
             (!('crm' in data) || data.crm is map) &&
             (!('personalNotes' in data) || (data.personalNotes is string && data.personalNotes.size() < 10000)) &&
             (!('files' in data) || data.files is list) &&
             data.savedAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidChat(data, userId, dealId) {
       return data.keys().hasAll(['userId', 'dealId', 'role', 'text', 'timestamp']) &&
              data.userId == userId &&
              data.dealId == dealId &&
              data.role in ['user', 'model'] &&
              data.text is string && data.text.size() < 50000 &&
              data.timestamp is timestamp;
    }

    function isValidLoiTracking(data) {
      return data.keys().hasAll(['userId', 'dealId', 'pdfUrl', 'sellerName', 'sentAt', 'opens', 'views']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.dealId is string && data.dealId.size() <= 128 &&
             data.pdfUrl is string && data.pdfUrl.size() < 1000000 &&
             data.sellerName is string && data.sellerName.size() < 200 &&
             data.sentAt is timestamp &&
             data.opens is number && data.opens >= 0 &&
             data.views is number && data.views >= 0 &&
             (!('lastOpenedAt' in data) || data.lastOpenedAt is timestamp) &&
             (!('lastViewedAt' in data) || data.lastViewedAt is timestamp) &&
             (!('followUp1Sent' in data) || data.followUp1Sent is bool) &&
             (!('followUp3Sent' in data) || data.followUp3Sent is bool) &&
             (!('followUp7Sent' in data) || data.followUp7Sent is bool);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['teamId', 'userId', 'userName', 'action', 'timestamp']) &&
             data.teamId is string && data.teamId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.action is string && data.action.size() <= 100 &&
             (!('dealId' in data) || data.dealId == null || data.dealId is string) &&
             (!('dealName' in data) || data.dealName == null || data.dealName is string) &&
             (!('metadata' in data) || data.metadata == null || data.metadata is map) &&
             data.timestamp is timestamp;
    }

    // Membership checks
    function isTeamMemberOf(targetUserId) {
      let myUserPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let targetUserPath = /databases/$(database)/documents/users/$(targetUserId);
      return isAuthenticated() && exists(myUserPath) && exists(targetUserPath) && 
             'teamId' in get(myUserPath).data && 'teamId' in get(targetUserPath).data && 
             get(myUserPath).data.teamId == get(targetUserPath).data.teamId;
    }

    function isTeamMember(teamId) {
        let myUserPath = /databases/$(database)/documents/users/$(request.auth.uid);
        return isAuthenticated() && exists(myUserPath) &&
               'teamId' in get(myUserPath).data && get(myUserPath).data.teamId == teamId;
    }

    // 3. The Rules

    match /loi_tracking/{loiId} {
      allow read: if true; // Public view for LOIs
      
      allow create: if isOwner(incoming().userId) &&
                       isValidId(loiId) && 
                       isValidLoiTracking(incoming());
                       
      // Split Actions for update
      allow update: if isValidLoiTracking(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().dealId == existing().dealId &&
                    incoming().pdfUrl == existing().pdfUrl &&
                    incoming().sellerName == existing().sellerName &&
                    incoming().sentAt == existing().sentAt &&
                    (
                      (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['lastOpenedAt', 'lastViewedAt', 'followUp1Sent', 'followUp3Sent', 'followUp7Sent', 'opens', 'views'])) || 
                      (
                        // Unauthenticated increment action
                        incoming().diff(existing()).affectedKeys().hasOnly(['opens', 'views', 'lastOpenedAt', 'lastViewedAt']) &&
                        incoming().opens >= existing().opens &&
                        incoming().views >= existing().views &&
                        incoming().lastOpenedAt == request.time &&
                        incoming().lastViewedAt == request.time
                      )
                    );
                    
      allow delete: if isOwner(existing().userId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isTeamMemberOf(userId);
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      
      allow update: if (isOwner(userId) || isTeamMemberOf(userId)) && 
                    isValidUser(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    (
                       (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasAny(['email', 'name', 'picture', 'profile', 'updatedAt', 'teamId'])) ||
                       (isTeamMemberOf(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['profile', 'updatedAt']))
                    );
                    
      allow delete: if isOwner(userId);

      match /deals/{dealId} {
        allow list: if isOwner(userId) || isTeamMemberOf(userId);
        allow get: if isOwner(userId) || isTeamMemberOf(userId);
        
        allow create: if (isOwner(userId) || isTeamMemberOf(userId)) && isValidId(dealId) && isValidDeal(incoming(), userId) && incoming().savedAt == request.time;
        
        allow update: if (isOwner(userId) || isTeamMemberOf(userId)) && isValidDeal(incoming(), userId) &&
                      incoming().userId == existing().userId &&
                      incoming().savedAt == existing().savedAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['url', 'dealData', 'analysis', 'metrics', 'crm', 'personalNotes', 'updatedAt', 'files']);
                      
        allow delete: if isOwner(userId) || isTeamMemberOf(userId);

        match /chats/{chatId} {
          allow read: if isOwner(userId) || isTeamMemberOf(userId);
          
          allow create: if (isOwner(userId) || isTeamMemberOf(userId)) && isValidId(chatId) && isValidChat(incoming(), userId, dealId) && incoming().timestamp == request.time;
          
          // Chats are immutable
          allow update: if false;
          
          allow delete: if isOwner(userId) || isTeamMemberOf(userId);
        }
      }
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated() && (teamId == request.auth.uid || isTeamMember(teamId));
      
      allow create: if isAuthenticated() && isValidId(teamId) && isValidTeam(incoming()) && 
                       incoming().ownerId == request.auth.uid &&
                       request.auth.uid in incoming().memberIds &&
                       incoming().createdAt == request.time;
                       
      allow update: if isAuthenticated() && isValidTeam(incoming()) &&
                       (teamId == request.auth.uid || isTeamMember(teamId)) &&
                       incoming().ownerId == existing().ownerId &&
                       incoming().createdAt == existing().createdAt &&
                       (
                         (existing().ownerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'memberIds', 'updatedAt', 'tier', 'stripeCustomerId', 'stripeSubscriptionId', 'lifetimeAccess'])) ||
                         (isTeamMember(teamId) && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']))
                       );
                       
      allow delete: if false; // Teams cannot be deleted directly
    }

    match /audit_logs/{logId} {
      // Members of the team can read logs
      allow read: if isAuthenticated() && isTeamMember(resource.data.teamId);
      
      // Members of the team can write logs
      allow create: if isAuthenticated() && isValidId(logId) && isValidAuditLog(incoming()) && 
                       (isTeamMember(incoming().teamId) || incoming().teamId == request.auth.uid) &&
                       incoming().userId == request.auth.uid &&
                       incoming().timestamp == request.time;
                       
      allow update, delete: if false; // Immutable logs
    }
  }
}
