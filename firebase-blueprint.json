{
  "entities": {
    "Team": {
      "title": "Team",
      "description": "Represents a billing account and shared workspace.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tier": { "type": "string", "enum": ["SOLOPRENEUR", "FAMILY_OFFICE", "M_AND_A"] },
        "stripeCustomerId": { "type": "string" },
        "stripeSubscriptionId": { "type": "string" },
        "lifetimeAccess": { "type": "boolean" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tier", "memberIds", "ownerId", "createdAt", "updatedAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Tracks user actions for corporate audit trails.",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "dealId": { "type": "string" },
        "dealName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["teamId", "userId", "userName", "action", "timestamp"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user data and investor profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "picture": { "type": "string", "format": "uri" },
        "profile": {
          "type": "object",
          "properties": {
            "goals": { "type": "string" },
            "mustHaves": { "type": "string" },
            "superpowers": { "type": "string" }
          }
        },
        "teamId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "createdAt"]
    },
    "Deal": {
      "title": "Deal",
      "description": "Stores a saved deal and its analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "dealData": {
          "type": "object",
          "properties": {
            "listingUrl": { "type": "string" },
            "askingPrice": { "type": "number" },
            "revenue": { "type": "number" },
            "sde": { "type": "number" },
            "keywords": { "type": "string" },
            "notes": { "type": "string" },
            "growthContext": { "type": "string" },
            "imageUrl": { "type": "string" },
            "hasFinancials": { "type": "boolean" },
            "callParticipants": { "type": "string" },
            "callSummary": { "type": "string" }
          }
        },
        "analysis": {
          "type": "object",
          "properties": {
            "markdown": { "type": "string" },
            "score": { "type": "number" },
            "initialScore": { "type": "number" }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "multiple": { "type": "number" },
            "margin": { "type": "number" },
            "status": { "type": "string" }
          }
        },
        "crm": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "financialsRequested": { "type": "boolean" },
            "ndaSigned": { "type": "boolean" },
            "pofSent": { "type": "boolean" },
            "cimReceived": { "type": "boolean" },
            "brokerCall": { "type": "boolean" },
            "sellerCall": { "type": "boolean" },
            "offerMade": { "type": "boolean" },
            "loiSent": { "type": "boolean" },
            "dueDiligence": { "type": "boolean" }
          }
        },
        "personalNotes": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "url", "savedAt"]
    },
    "Chat": {
      "title": "Chat Message",
      "description": "Stores a chat message related to a deal.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "dealId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "dealId", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles."
    },
    "/users/{userId}/deals/{dealId}": {
      "schema": { "$ref": "#/entities/Deal" },
      "description": "User's saved deals."
    },
    "/users/{userId}/deals/{dealId}/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat messages for a deal."
    },
    "/teams/{teamId}": {
      "schema": { "$ref": "#/entities/Team" },
      "description": "Teams and organizations."
    },
    "/audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Corporate audit trails."
    }
  }
}
