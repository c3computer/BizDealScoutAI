{
  "manifest_version": 3,
  "name": "DealScout",
  "version": "1.0",
  "description": "DealScout companion extension for scraping deals and managing pipeline.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://*.bizbuysell.com/*",
    "https://*.bizquest.com/*",
    "http://localhost:3000/*",
    "https://*.run.app/*"
  ],
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.bizbuysell.com/*", "https://*.bizquest.com/*"],
      "js": ["content.js"]
    }
  ]
}
